<screen name="home">
	<styles>
		<style name="header_btn_normal" bg_color="0xFAFAFA" radius="10" pad_all="0" flex_grow="1" />
		<style name="header_btn_focused" bg_color="0x2196F3" />
	</styles>

	<view
		extends="lv_obj"
		style_bg_color="0xD9D9D9"
		flex_flow="row_wrap"
		style_pad_row="20"
		style_pad_column="20"
		style_pad_all="20"
	>
		<lv_obj
			style_bg_color="0xFAFAFA"
			height="48"
			flex_grow="1"
			style_radius="10"
			flex_flow="row"
			style_pad_all="0"
			style_flex_cross_place="center"
			style_pad_row="0"
			style_pad_column="0"
			scrollable="false"
		>
			<lv_button style_flex_grow="1" height="100%">
				<bind_style name="header_btn_normal" subject="dark_theme_on" ref_value="0" selector="default" />
				<bind_style name="header_btn_focused" subject="dark_theme_on" ref_value="0" selector="focused" />
				<lv_label text="Home btn" />
			</lv_button>

			<lv_button style_flex_grow="1" height="100%">
				<bind_style name="header_btn_normal" subject="dark_theme_on" ref_value="0" />
				<lv_label text="Theme switch btn" />
			</lv_button>

			<lv_button style_flex_grow="1" height="100%">
				<bind_style name="header_btn_normal" subject="dark_theme_on" ref_value="0" />
				<lv_label text="Settings btn" />
			</lv_button>

			<lv_obj width="36" height="100%" style_opa="0" />

			<lv_slider flex_grow="3" />

			<lv_obj width="36" height="100%" style_opa="0" />

			<lv_button style_flex_grow="1" height="100%">
				<bind_style name="header_btn_normal" subject="dark_theme_on" ref_value="0" />
				<lv_label text="ELM Status btn" />
			</lv_button>
		</lv_obj>
	</view>
</screen>
